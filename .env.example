# Local dev — copy to .env and fill in. .env is gitignored.

# Telegram bot (leave blank if you're not running the bot)
BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
MINI_APP_URL=https://your-mini-app.example.com

# Backend
BACKEND_URL=http://localhost:8000
DATABASE_URL=sqlite:///./clil_bot.db

# Comma-separated Telegram user IDs recognized as teachers/mentors.
TEACHER_TELEGRAM_IDS=1

# Shared secret between backend and bot (internal endpoints).
INTERNAL_BOT_TOKEN=dev-secret-change-me

# Optional — Groq AI for adaptive hints. Leave empty to disable.
GROQ_API_KEY=

# Frontend reads .env from project root via Vite envDir: '../'
VITE_API_URL=/api
